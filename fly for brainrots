-- ========== CORE FUNCTIONS ==========
local function getCharacterRoot(plr)
    local char = plr.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
end

local function teleportSelf(pos)
    local root = getCharacterRoot(player)
    if root then
        root.CFrame = CFrame.new(pos.X, pos.Y + 3, pos.Z)
        return true
    end
    return false
end

-- Find home/base position
local function findHomePosition()
    -- Try to find base/spawn location
    local spawn = Workspace:FindFirstChild("SpawnLocation")
    if spawn then
        return spawn.Position
    end
    
    -- Look for any part with "base" or "home" in name
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local name = obj.Name:lower()
            if name:find("base") or name:find("home") or name:find("spawn") then
                return obj.Position
            end
        end
    end
    
    -- Fallback to center of map
    return Vector3.new(0, 10, 0)
end

-- Teleport to home
local function teleportToHome()
    if not HOME_POSITION then
        HOME_POSITION = findHomePosition()
    end
    teleportSelf(HOME_POSITION)
    statusText.Text = "🏠 Teleported to Home!"
    statusText.TextColor3 = colors.blue
    task.wait(2)
    statusText.Text = "✅ TOXIC HUB READY | GO TO = teleport | AUTO FARM = auto collect"
    statusText.TextColor3 = colors.toxic
    return true
end

-- Teleport to player
local function teleportToPlayer(target)
    local targetRoot = getCharacterRoot(target)
    if targetRoot then
        teleportSelf(targetRoot.Position)
        statusText.Text = "✅ Teleported to " .. target.Name
        return true
    end
    statusText.Text = "❌ Player not found"
    return false
end

-- Press E function
local function pressE()
    VirtualInput:SendKeyEvent(true, "E", false, game)
    task.wait(0.1)
    VirtualInput:SendKeyEvent(false, "E", false, game)
end

-- Find nearby brainrots
local function findNearbyBrainrots()
    local character = player.Character
    if not character then return {} end
    
    local root = getCharacterRoot(player)
    if not root then return {} end
    
    local charPos = root.Position
    local brainrots = {}
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj and obj.Parent then
            local name = obj.Name:lower()
            local isBrainrot = false
            
            if name:find("brainrot") or name:find("aschend") or name:find("og") then
                isBrainrot = true
            end
            
            if isBrainrot then
                local objPos = nil
                if obj:IsA("BasePart") then
                    objPos = obj.Position
                elseif obj:IsA("Model") and obj.PrimaryPart then
                    objPos = obj.PrimaryPart.Position
                end
                
                if objPos then
                    local dist = (charPos - objPos).Magnitude
                    if dist <= FARM_RADIUS then
                        table.insert(brainrots, {obj = obj, dist = dist})
                    end
                end
            end
        end
    end
    
    table.sort(brainrots, function(a, b) return a.dist < b.dist end)
    return brainrots
end

-- Auto farm loop
local farmRunning = false
local farmThread = nil

local function startAutoFarm()
    if farmThread then return end
    
    farmRunning = true
    farmThread = task.spawn(function()
        while farmRunning do
            if AUTO_FARM_ENABLED then
                local brainrots = findNearbyBrainrots()
                
                if #brainrots > 0 then
                    pressE()
                    collectedCount = collectedCount + 1
                    updateFarmStats()
                    statusText.Text = "🤖 Auto Farm: Collected " .. collectedCount .. " brainrots"
                    statusText.TextColor3 = colors.toxic
                end
            end
            task.wait(0.3)
        end
    end)
end

local function stopAutoFarm()
    farmRunning = false
    if farmThread then
        coroutine.close(farmThread)
        farmThread = nil
    end
end

-- Update UI stats
local function updateFarmStats()
