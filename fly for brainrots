            nameLabel.Parent = container
            
            local gotoBtn = Instance.new("TextButton")
            gotoBtn.Size = UDim2.new(0.28, 0, 0, 32)
            gotoBtn.Position = UDim2.new(0.68, 0, 0, 6)
            gotoBtn.BackgroundColor3 = colors.blue
